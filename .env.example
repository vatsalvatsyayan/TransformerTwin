# TransformerTwin — Environment Configuration Example
# Copy this file to .env and adjust values for your environment.
# .env is gitignored. This file (.env.example) is committed.

# ---------------------------------------------------------------------------
# Backend server
# ---------------------------------------------------------------------------

# Port for uvicorn. Default is 8000 but 8000 may be taken on some machines.
# Start backend with: cd backend && .venv/bin/python -m uvicorn main:app --reload --port 8001
BACKEND_PORT=8001

# Database file path (relative to backend/ directory)
DB_PATH=transformer_twin.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Frontend dev server
# ---------------------------------------------------------------------------

# Vite dev server port (default 5173)
VITE_PORT=5173

# Backend WebSocket URL — update BACKEND_PORT here to match above
VITE_WS_URL=ws://localhost:8001/ws

# Backend REST API base URL — must match BACKEND_PORT
VITE_API_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Notes for integration
# ---------------------------------------------------------------------------
# When changing BACKEND_PORT, update BOTH:
#   frontend/src/lib/api.ts        (REST base URL)
#   frontend/src/hooks/useWebSocket.ts  (WebSocket URL)
# Do NOT hardcode port numbers in those files — read from import.meta.env or a lib/config.ts constant.
